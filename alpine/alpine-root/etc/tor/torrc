Log notice syslog
ExitRelay 0
ExcludeExitNodes {am}, {az}, {by}, {ee}, {ge}, {kg}, {kz}, {lt}, {ly}, {md}, {ru}, {tj}, {tm}, {ua}, {uz}, {ie}
AvoidDiskWrites 1

# https://github.com/jmcorgan/fips/blob/0f24333c0d02d6cceaaaff58301d6e556abd2094/packaging/torrc.fips
SocksPort 127.0.0.1:9050 IsolateSOCKSAuth
CookieAuthentication 1
CookieAuthFileGroupReadable 1
CookieAuthFile /run/tor/control.authcookie
#HiddenServiceMaxStreams 100
#HiddenServiceMaxStreamsCloseCircuit 1
#HiddenServiceEnableIntroDoSDefense 1
#HiddenServiceEnableIntroDoSRatePerSec 25
#HiddenServiceEnableIntroDoSBurstPerSec 200
#HiddenServicePoWDefensesEnabled 1
#HiddenServicePoWQueueRate 250
#HiddenServicePoWQueueBurst 2500
VanguardsLiteEnabled 1
ConnectionPadding 1
SafeLogging 1

#UseBridges 1
#ClientTransportPlugin obfs4,webtunnel exec /usr/bin/lyrebird
#ExtORPort auto
#Bridge obfs4 ...
