. {
  loop

  bind 127.0.0.1 ::1

  #log
  #errors

  cache {
    prefetch 4096 20s
    serve_stale 48h
  }

  forward . dns://127.0.0.1:5350 {
    force_tcp
    policy sequential
    health_check 10s
    failfast_all_unhealthy_upstreams
  }

